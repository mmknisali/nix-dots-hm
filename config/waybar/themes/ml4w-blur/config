{
    "layer": "top",
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,    
    "spacing": 4,

    "include": [
        "~/.config/waybar/modules.json"
    ],

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],

    "modules-center": [],

    "modules-right": [
        "custom/cliphist",
        "pulseaudio",
        "network",
        "cpu",
        "memory",
        "battery",
        "clock",
        "tray"
    ],

    "clock": {
        "format": "󰱒 {:%H:%M}",
        "format-alt": "󰱒 {:%a %b %d}"
    },
    "cpu": {
        "format": "󰘚 {}%"
    },
    "memory": {
        "format": "󰍔 {}%"
    },
    "battery": {
        "format": "󰁹 {}%",
        "format-charging": "󰂄 {}%",
        "format-plugged": "󰂄 {}%"
    },
    "network": {
        "format-wifi": "󰤨 {essid} ",
        "format-ethernet": "󰈀 "
    },
    "pulseaudio": {
        "format": "󰝚 {volume}%",
        "format-muted": "󰝞 {volume}%"
    },
    "tray": {
        "spacing": 8
    }
}
