{
    "layer": "top",
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,    
    "spacing": 0,

    "include": [
        "~/.config/waybar/modules.json"
    ],

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],

    "modules-center": [],

    "modules-right": [
        "custom/cliphist",
        "pulseaudio",
        "network",
        "cpu",
        "memory",
        "battery",
        "clock",
        "tray"
    ],

    "clock": {
        "format": "{:%H:%M}"
    },
    "cpu": {
        "format": "{usage}%"
    },
    "memory": {
        "format": "{}%"
    },
    "battery": {
        "format": "{capacity}%"
    },
    "network": {
        "format-wifi": "{essid}"
    },
    "pulseaudio": {
        "format": "{volume}%"
    }
}
